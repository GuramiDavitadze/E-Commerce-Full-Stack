{
    "/api/category":{
        "post":{
            "summary":"Create new category",
            "tags":[
                "Category"
            ],
            "requestBody":{
                "required":true,
                "content":{
                    "application/json":{
                        "schema":{
                            "type": "object",
                            "required": [
                                "content"
                            ],
                            "properties":{
                                "content":{
                                    "type":"string"
                                }

                            }
                        }

                    }
                }
            },
            "responses":{
                "201":{
                    "description":"Category Created Successfully"
                },
                "400":{
                    "description":"Validation Error"
                },
                "409":{
                    "description":"Category already exist"
                },
                "500":{
                    "description":"Internal Server Error"
                }
                
            }
        }
    }
}